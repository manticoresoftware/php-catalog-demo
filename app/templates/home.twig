            const clearUrl = new URL(lastCatalogUrl.toString());
            setFacetSelectionInUrl(clearUrl, paramName, []);
            resetPagination(clearUrl);
            clearLink.href = clearUrl.toString();
        }
    };
    const syncFacetCountsFromDoc = (nextCategoryPanel, nextTagPanel) => {
        const sync = (currentSelector, nextPanel) => {
            const currentPanel = document.querySelector(currentSelector);
            if (!currentPanel || !nextPanel) {
                return;
            }
            const nextMap = new Map();
            nextPanel.querySelectorAll('.facet-option[data-facet-id]').forEach((el) => {
                if (!(el instanceof HTMLAnchorElement)) {
                    return;
                }
                const facetId = el.dataset.facetId || '';
                const countEl = el.querySelector('.facet-count');
                if (!facetId || !(countEl instanceof HTMLElement)) {
                    return;
                }
                nextMap.set(facetId, countEl.textContent || '(0)');
            });
            currentPanel.querySelectorAll('.facet-option[data-facet-id]').forEach((el) => {
                if (!(el instanceof HTMLAnchorElement)) {
                    return;
                }
                const facetId = el.dataset.facetId || '';
                const countEl = el.querySelector('.facet-count');
                if (!facetId || !(countEl instanceof HTMLElement)) {
                    return;
                }
                if (nextMap.has(facetId)) {
                    countEl.textContent = nextMap.get(facetId);
