        const selectedSet = new Set(selected);
        const options = panel.querySelectorAll('.facet-option[data-facet-id]');
        options.forEach((link) => {
            if (!(link instanceof HTMLAnchorElement)) {
                return;
            }
            const facetId = link.dataset.facetId || '';
            const active = facetId !== '' && selectedSet.has(facetId);
            link.setAttribute('aria-current', active ? 'page' : 'false');
        });
