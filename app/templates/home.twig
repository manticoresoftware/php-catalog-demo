    const getFacetSelectionOrderFromDom = (panelSelector) => {
        const panel = document.querySelector(panelSelector);
        if (!panel) {
            return [];
        }
        return Array.from(panel.querySelectorAll('.facet-option[aria-current="page"][data-facet-id]'))
            .map((el) => el instanceof HTMLAnchorElement ? (el.dataset.facetId || '') : '')
            .filter(Boolean);
    };
    const applyLiveInputsToUrl = (url, facetSource = 'url') => {
        // Any criteria update starts a fresh pagination session.
        url.searchParams.delete('scroll');
        const selectedCategoryIds = facetSource === 'dom'
            ? getFacetSelectionOrderFromDom('[data-ajax-category-panel]')
            : getFacetSelectionOrderFromUrl('category', url);
        const selectedTagIds = facetSource === 'dom'
            ? getFacetSelectionOrderFromDom('[data-ajax-tag-panel]')
            : getFacetSelectionOrderFromUrl('tag', url);
        setFacetSelectionInUrl(url, 'category', selectedCategoryIds);
        setFacetSelectionInUrl(url, 'tag', selectedTagIds);
        const sortSelect = document.querySelector('[data-catalog-sort-select]');
        if (sortSelect instanceof HTMLSelectElement) {
            applySortSelectionToUrl(url, sortSelect.value);
        }

