            const neutral = input.dataset.neutral;
            return typeof neutral === 'string' && neutral !== '' && value === neutral;
        };
        const searchInput = document.querySelector('[data-autocomplete-input]');
        if (searchInput instanceof HTMLInputElement) {
            const q = searchInput.value.trim();
            if (q === '') {
                url.searchParams.delete('q');
