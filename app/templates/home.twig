    const initRangeSliders = () => {
        const pairs = document.querySelectorAll('.filters-grid [data-range-pair]');
        pairs.forEach((pair) => {
            const minInput = pair.querySelector('input[type="range"][data-range-role="min"]');
            const maxInput = pair.querySelector('input[type="range"][data-range-role="max"]');
            if (!(minInput instanceof HTMLInputElement) || !(maxInput instanceof HTMLInputElement)) {
                return;
            }
            const targetId = minInput.dataset.rangeValueTarget || maxInput.dataset.rangeValueTarget || '';
            const target = targetId ? document.getElementById(targetId) : null;
            const track = pair.querySelector('.range-dual');
            const minBound = Number.parseFloat(minInput.min || '0');
            const maxBound = Number.parseFloat(maxInput.max || '100');
            const span = Math.max(1, maxBound - minBound);

            const render = (sourceInput = null) => {
                let minVal = Number.parseFloat(minInput.value || String(minBound));
                let maxVal = Number.parseFloat(maxInput.value || String(maxBound));
                if (minVal > maxVal) {
                    if (sourceInput === maxInput) {
                        minVal = maxVal;
                    } else {
                        maxVal = minVal;
                    }
                }
                minInput.value = String(minVal);
                maxInput.value = String(maxVal);

                if (target) {
                    target.textContent = `${minInput.value} - ${maxInput.value}`;
                }
                if (track instanceof HTMLElement) {
                    const start = ((minVal - minBound) / span) * 100;
                    const end = ((maxVal - minBound) / span) * 100;
                    track.style.setProperty('--range-start', `${start}%`);
                    track.style.setProperty('--range-end', `${end}%`);
                }
            };

            render();
            minInput.addEventListener('input', () => render(minInput));
            maxInput.addEventListener('input', () => render(maxInput));
            minInput.addEventListener('change', () => render(minInput));
            maxInput.addEventListener('change', () => render(maxInput));
        });
    };
    const initFacetLiveSearch = () => {
        const bind = (selector) => {
            const panel = document.querySelector(selector);
            if (!panel) {
                return;
            }
            const input = panel.querySelector('[data-facet-search]');
            const list = panel.querySelector('.facet-list');
            const clearBtn = panel.querySelector('[data-facet-search-clear]');
            if (!(input instanceof HTMLInputElement) || !(list instanceof HTMLElement)) {
                return;
            }
            if (input.dataset.liveSearchBound === '1') {
                return;
            }
            const applyFilter = () => {
                const term = input.value.trim().toLowerCase();
                const rows = list.querySelectorAll('.facet-row');
                rows.forEach((row) => {
                    if (!(row instanceof HTMLElement)) {
                        return;
                    }
                    if (term === '') {
                        row.hidden = false;
                        return;
                    }
                    const nameNode = row.querySelector('.facet-name');
                    const text = (nameNode?.textContent || '').toLowerCase();
                    row.hidden = !text.includes(term);
                });
                if (clearBtn instanceof HTMLButtonElement) {
                    const hasValue = term !== '';
                    clearBtn.classList.toggle('is-visible', hasValue);
                    clearBtn.disabled = !hasValue;
                }
            };
            input.addEventListener('input', applyFilter);
            if (clearBtn instanceof HTMLButtonElement) {
                clearBtn.addEventListener('click', () => {
                    input.value = '';
                    applyFilter();
                    input.focus({ preventScroll: true });
                });
            }
            input.dataset.liveSearchBound = '1';
            applyFilter();
        };
        bind('[data-ajax-category-panel]');
        bind('[data-ajax-tag-panel]');
    };

    const initMainWidgets = () => {
        sanitizeFacetLabels();
        syncFacetUiFromUrl();
        initAutocomplete();
        initSortInteractions();
        initFilterAutoSubmit();
        initRangeSliders();
        initFacetLiveSearch();
    };

    initMainWidgets();
});
</script>
</body>
</html>
