            const url = new URL(lastCatalogUrl.toString());
            url.searchParams.set('page', '1');
            const sortSelect = document.querySelector('[data-catalog-sort-select]');
            if (sortSelect instanceof HTMLSelectElement) {
                applySortSelectionToUrl(url, sortSelect.value);
            }

            // Keep current query text if user has edited it but not submitted yet.
            const searchInput = document.querySelector('[data-autocomplete-input]');
            if (searchInput instanceof HTMLInputElement) {
                const q = searchInput.value.trim();
                if (q === '') {
                    url.searchParams.delete('q');
                } else {
                    url.searchParams.set('q', q);
                }
            }

            // Replace only filter params from live form inputs.
            const filterKeys = [
                'price_min',
                'price_max',
                'release_year_min',
                'release_year_max',
                'player_count_min',
                'player_count_max',
                'play_time_min',
                'play_time_max',
            ];
            const isNeutralFilterInput = (input) => {
                if (!(input instanceof HTMLInputElement)) {
                    return true;
                }
                const value = input.value.trim();
                if (value === '') {
                    return true;
                }
                const neutral = input.dataset.neutral;
                return typeof neutral === 'string' && neutral !== '' && value === neutral;
            };
            filterKeys.forEach((key) => url.searchParams.delete(key));
            inputs.forEach((input) => {
                if (!(input instanceof HTMLInputElement) || !input.name) {
