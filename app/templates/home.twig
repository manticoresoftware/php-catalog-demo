        setFacetPanelState('[data-ajax-tag-panel]', 'tag');
        reorderFacetOptions();
    };
    const reorderFacetPanel = (panel, paramName, selectedOrderOverride = null) => {
        if (!panel) {
            return;
        }
        const list = panel.querySelector('.facet-list');
        if (!list) {
            return;
        }
        const rows = Array.from(list.querySelectorAll('.facet-row'));
        if (!rows.length) {
            return;
        }
        const selectedOrder = selectedOrderOverride ?? getFacetSelectionOrderFromUrl(paramName);
        const selectedIndexMap = new Map(selectedOrder.map((facetId, idx) => [facetId, idx]));

        const selectedRows = [];
        const unselectedRows = [];
        rows.forEach((row, idx) => {
            const link = row.querySelector('.facet-option');
            const originalIndex = link instanceof HTMLAnchorElement
                ? Number.parseInt(link.dataset.facetIndex || String(idx), 10)
                : idx;
            if (!(link instanceof HTMLAnchorElement)) {
                unselectedRows.push({ row, idx, originalIndex });
                return;
            }
            const active = link.getAttribute('aria-current') === 'page';
            if (!active) {
                unselectedRows.push({ row, idx, originalIndex });
                return;
            }
            const facetId = link.dataset.facetId || '';
            const orderIdx = selectedIndexMap.has(facetId) ? selectedIndexMap.get(facetId) : Number.MAX_SAFE_INTEGER;
            selectedRows.push({ row, idx, originalIndex, orderIdx });
        });

        selectedRows.sort((a, b) => {
            if (a.orderIdx !== b.orderIdx) {
                return a.orderIdx - b.orderIdx;
            }
            return a.idx - b.idx;
        });
        unselectedRows.sort((a, b) => a.originalIndex - b.originalIndex);

        const fragment = document.createDocumentFragment();
        selectedRows.forEach((item) => fragment.appendChild(item.row));
        unselectedRows.forEach((item) => fragment.appendChild(item.row));
        list.appendChild(fragment);
    };
    const reorderFacetBlock = (panelSelector, paramName, selectedOrderOverride = null) => {
        const panel = document.querySelector(panelSelector);
        reorderFacetPanel(panel, paramName, selectedOrderOverride);
    };
    const reorderFacetOptions = () => {
        reorderFacetBlock('[data-ajax-category-panel]', 'category');
        reorderFacetBlock('[data-ajax-tag-panel]', 'tag');
    };
    const applyFacetClickReorder = (link) => {
        const panel = link.closest('[data-ajax-category-panel], [data-ajax-tag-panel]');
        if (!panel) {
            return;
        }
        const paramName = panel.hasAttribute('data-ajax-category-panel') ? 'category' : 'tag';
        const facetId = link.dataset.facetId || '';
        if (facetId === '') {
            return;
        }
        const isActive = link.getAttribute('aria-current') === 'page';
        if (!isActive) {
            link.setAttribute('aria-current', 'page');
        } else {
            link.setAttribute('aria-current', 'false');
