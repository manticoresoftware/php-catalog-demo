                const url = new URL(lastCatalogUrl.toString(), window.location.origin);
                applyLiveInputsToUrl(url, 'dom');
                url.searchParams.set('page', '1');
                fetchAndReplaceCatalog(url.toString(), { preserveFacetCounts: true });
            }, delayMs);
        };

        input.addEventListener('input', () => {
            const term = input.value.trim();
            syncClearButton();
            triggerLiveSearch();
            if (term.length < minQueryLen) {
