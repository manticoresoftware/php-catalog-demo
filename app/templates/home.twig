    const initAutocomplete = () => {
        const input = document.querySelector('[data-autocomplete-input]');
        const list = document.querySelector('[data-autocomplete-results]');
        const clearBtn = document.querySelector('[data-main-search-clear]');
        if (!input || !list) {
            return;
        }

        const endpoint = input.dataset.autocompleteEndpoint;
        const minQueryLen = Math.max(1, Number.parseInt(input.dataset.minQueryLen || '2', 10) || 2);
        let suggestController = null;
        let suggestDebounce = null;
        let liveSearchDebounce = null;
        const wrapper = input.closest('.autocomplete');
        const syncClearButton = () => {
            const hasValue = input.value.trim() !== '';
            if (wrapper instanceof HTMLElement) {
                wrapper.classList.toggle('has-value', hasValue);
            }
            if (!(clearBtn instanceof HTMLButtonElement)) {
                return;
            }
            clearBtn.classList.toggle('is-visible', hasValue);
            clearBtn.disabled = !hasValue;
        };

        const hideList = () => {
            list.hidden = true;
            list.innerHTML = '';
        };

        const renderSuggestions = (payload) => {
            const suggestData = payload?.suggestions?.suggest?.data ?? [];
            const qSuggestData = payload?.suggestions?.qsuggest?.data ?? [];
            const combined = [...suggestData, ...qSuggestData]
                .map(item => item?.suggestion ?? item?.token ?? '')
                .filter(Boolean);
            const unique = Array.from(new Set(combined)).slice(0, 8);
            if (!unique.length) {
                hideList();
                return;
            }
            list.innerHTML = '';
            unique.forEach(text => {
                const li = document.createElement('li');
                li.tabIndex = 0;
                li.textContent = text;
                const apply = () => {
                    input.value = text;
                    syncClearButton();
                    hideList();
                    const url = new URL(lastCatalogUrl.toString(), window.location.origin);
                    applyLiveInputsToUrl(url, 'dom');
                    const hasActiveFacetFilters =
                        getFacetSelectionOrderFromDom('[data-ajax-category-panel]').length > 0
                        || getFacetSelectionOrderFromDom('[data-ajax-tag-panel]').length > 0;
                    fetchAndReplaceCatalog(url.toString(), { preserveFacetCounts: hasActiveFacetFilters });
                };
                li.addEventListener('mousedown', (evt) => {
                    evt.preventDefault();
                    apply();
                });
                li.addEventListener('keydown', (evt) => {
                    if (evt.key === 'Enter') {
                        evt.preventDefault();
                        apply();
                    }
                });
                list.appendChild(li);
            });
            list.hidden = false;
        };

        const fetchSuggestions = (term) => {
            if (!endpoint) {
                return;
            }
            if (suggestController) {
