{
    "name": "manticoresearch/catalog-app",
    "type": "project",
    "require": {
        "php": "^8.1",
        "slim/slim": "^4.12",
        "slim/psr7": "^1.6",
        "slim/twig-view": "^3.3",
        "twig/twig": "^3.10",
        "vlucas/phpdotenv": "^5.6",
        "league/csv": "^9.0",
        "monolog/monolog": "^3.0",
        "symfony/var-dumper": "^6.0",
        "manticoresoftware/manticoresearch-php": "4.0.1"
    },
    "autoload": {
        "psr-4": {
            "ManticoreDemo\\": "src/"
        }
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
